{
  "expo": {
    "name": "Zabrat",
    "slug": "zabrat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "zabrat",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5A623"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.zabrat.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5A623",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.zabrat.app"
    },
    "plugins": [
      "expo-router",
      "expo-sharing"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3bc6e01d-bba7-4e0a-ae6f-444eacacd1a0"
      }
    },
    "owner": "centrelaer"
  }
}
